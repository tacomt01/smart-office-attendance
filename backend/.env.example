# ──────────────────────────────────────────────────────────────
# Smart Office — Backend Environment (TEMPLATE)
# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริงของคุณ:
#   cp .env.example .env        (Windows: copy .env.example .env)
# ⚠️ ห้าม commit ค่า secret จริงลง git — ไฟล์ .env ถูก ignore ไว้แล้ว
# ──────────────────────────────────────────────────────────────

# ── Core server ──
PORT=3000
DATABASE_URL="file:./dev.db"
JWT_SECRET="change-this-to-a-long-random-secret"

# ── AI provider selection ──
# เลือก provider: gemini (default บน server) | groq | claude
# local dev สามารถใช้ claude ได้ (subscription, ไม่เสียค่า API)
AI_PROVIDER=gemini

# กำหนด model ของแต่ละ provider
CLAUDE_MODEL=claude-haiku-4-5
GEMINI_MODEL=gemini-3.5-flash
GROQ_MODEL=llama-3.3-70b-versatile

# ── Free-tier API keys ──
# Gemini: https://aistudio.google.com/apikey
# Groq:   https://console.groq.com
GEMINI_API_KEY="your-gemini-api-key"
GROQ_API_KEY="your-groq-api-key"

# ── Claude auth (local only) ──
# CLAUDE_CODE_OAUTH_TOKEN=  # local only: run `claude setup-token`; do NOT set ANTHROPIC_API_KEY (avoids API charges)
